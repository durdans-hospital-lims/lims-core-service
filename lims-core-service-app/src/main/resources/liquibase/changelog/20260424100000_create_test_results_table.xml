<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.7.xsd">

    <changeSet id="20260424100000-create-test-results-table" author="S.K.L. Undulanga">

        <createTable tableName="test_results">

            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="order_item_id" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>

            <column name="status" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>

            <column name="mlt_notes" type="TEXT"/>

            <column name="return_reason" type="TEXT"/>

            <column name="clinical_note" type="TEXT"/>

            <column name="technically_verified_by" type="VARCHAR(255)"/>

            <column name="technically_verified_at" type="TIMESTAMP"/>

            <column name="clinically_authorized_by" type="VARCHAR(255)"/>

            <column name="clinically_authorized_at" type="TIMESTAMP"/>

            <column name="returned_by" type="VARCHAR(255)"/>

            <column name="returned_at" type="TIMESTAMP"/>

            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>

            <column name="created_by" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>

            <column name="updated_at" type="TIMESTAMP"/>

            <column name="updated_by" type="VARCHAR(255)"/>

            <column name="is_deleted" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>

            <column name="version" type="BIGINT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>

        </createTable>

        <addForeignKeyConstraint
                baseTableName="test_results"
                baseColumnNames="order_item_id"
                referencedTableName="order_items"
                referencedColumnNames="id"
                constraintName="fk_test_results_order_item"/>

        <createIndex
                indexName="idx_test_results_order_item_id"
                tableName="test_results">
            <column name="order_item_id"/>
        </createIndex>

        <createIndex
                indexName="idx_test_results_status"
                tableName="test_results">
            <column name="status"/>
        </createIndex>

        <createIndex
                indexName="idx_test_results_is_deleted"
                tableName="test_results">
            <column name="is_deleted"/>
        </createIndex>

    </changeSet>

</databaseChangeLog>